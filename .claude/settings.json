{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(git:*)",
      "Bash(python3:*)"
    ],
    "deny": [
      "Write(.env*)",
      "Write(**/*.key)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/router/user_prompt_submit.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
