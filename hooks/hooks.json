{
  "description": "Wavelength plugin hooks — shared memory guidance and skill routing",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/context/session_start.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/router/user_prompt_submit.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
